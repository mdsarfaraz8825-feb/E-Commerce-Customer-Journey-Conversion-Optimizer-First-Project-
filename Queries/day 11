use ecommerce;

select 
   user_id,
   datediff(
           (select max(event_time) from events),
           max(event_time)
   ) as recency_days
   from events
   where event_type = 'purchase'
   group by user_id
   order by recency_days;
   
   select 
       user_id,
       count(*) as frequency
	from events
    where event_type = 'purchase'
    group by user_id
    order by frequency desc;
    
    select
        e.user_id,
        sum(p.price) as monetory
	from events e
    join products p
         ON e.product_id = p.product_id
	where e.event_type = 'purchase'
    group by e.user_id
    order by monetory desc;
